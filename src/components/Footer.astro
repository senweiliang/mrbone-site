---
const today = new Date();
---

<footer>
	<div class="inner">
		<span>&copy; {today.getFullYear()} mrbone</span>
		<span class="dim">种下一棵树，最好的时间是十年前，其次是现在。</span>
	</div>
</footer>
<style>
	footer {
		border-top: 1px solid var(--rule);
		margin-top: 4em;
	}
	.inner {
		max-width: 680px;
		margin: 0 auto;
		padding: 2em 1em 3em;
		display: flex;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 1em;
		color: var(--ink-faint);
		font-size: 0.88rem;
	}
	.dim {
		font-style: italic;
	}
	@media (max-width: 560px) {
		.inner { flex-direction: column; gap: 0.4em; }
	}
</style>
